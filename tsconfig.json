{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "$/*": ["./src/lib/*"],
      "@/*": ["./src/routes/*"]
    },
    "forceConsistentCasingInFileNames": true,
    "types": ["./worker-configuration.d.ts", "node"]
  }
}
